  "keyFeatures": [
    "Request router with parameterized DN routing",
    "Legacy Operation class for LDAP operation handling",
    "Schema support with attribute types and object classes",
    "SSL/TLS and UNIX socket support",
    "Multi-threading and prefork server modes",
    "Attribute range retrieval support",
    "Filter parsing and matching engine"
